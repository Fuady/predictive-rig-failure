# Copy this file to .env and fill in your values
# cp .env.example .env

# MLflow tracking server URI (default: local)
MLFLOW_TRACKING_URI=http://localhost:5000

# Model serving
MODEL_NAME=pdm_xgboost
MODEL_STAGE=Production
API_HOST=0.0.0.0
API_PORT=8000

# Dashboard
DASHBOARD_PORT=8501
API_BASE_URL=http://localhost:8000

# Alert thresholds
FAILURE_PROB_HIGH_THRESHOLD=0.75
FAILURE_PROB_MEDIUM_THRESHOLD=0.45
RUL_CRITICAL_HOURS=48
RUL_WARNING_HOURS=120

# Data paths
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
FEATURES_DIR=data/features
